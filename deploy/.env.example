# ============================================
# ОБЩИЕ НАСТРОЙКИ
# ============================================
NODE_ENV=production
DOMAIN=
EMAIL=

# ============================================
# POSTGRESQL
# ============================================
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=

# ============================================
# BACKEND (Spring Boot)
# ============================================
BACKEND_PORT=8080
AI_SERVICE_URL=http://ai-service:8000

# JWT настройки
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=2592000000

# ============================================
# FRONTEND (React)
# ============================================
FRONTEND_PORT=3000
VITE_API_URL=https://api.finsovetnik-ai.ru

# ============================================
# AI SERVICE (Python)
# ============================================
AI_SERVICE_PORT=8000
OPENAI_API_KEY=

# ============================================
# SSH ТУННЕЛЬ К БД (опционально)
# ============================================
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_KEY_PATH=/root/.ssh/id_rsa
DB_SSH_TUNNEL_PORT=5433

# ============================================
# NGINX
# ============================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443